# =============================================================
# VARIÁVEIS DE AMBIENTE — Backend da Academia
# =============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o .env no git!
# =============================================================

# ---- Servidor -----------------------------------------------
PORT=3000

# ---- Banco de dados (PostgreSQL) ----------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=academia_db
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Pool de conexões (opcional — valores padrão já são adequados para dev)
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONN_TIMEOUT=5000

# ---- Segurança ----------------------------------------------
# Segredo para geração de JWT (quando implementado)
# JWT_SECRET=troque_por_uma_string_longa_e_aleatoria
# JWT_EXPIRES_IN=8h

# ---- Ambiente -----------------------------------------------
NODE_ENV=development
